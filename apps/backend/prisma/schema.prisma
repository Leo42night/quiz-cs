generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model users {
  id             Int              @id @default(autoincrement())
  email          String           @unique
  name           String?
  profile_url    String?
  score_max      Int              @default(0)
  score          Int              @default(0)
  user_questions user_questions[]
}

model questions {
  id             Int              @id @default(autoincrement())
  category       Int
  language       Int
  type           Int
  question       String
  answer         String
  correct_answer String
  difficulty     Int
  points         Int
  user_questions user_questions[]
  updated_at     Int @default(0)    
}

model user_questions {
  user_id     Int
  question_id Int
  question    questions @relation(fields: [question_id], references: [id])
  user        users     @relation(fields: [user_id], references: [id])

  @@id([user_id, question_id])
}
