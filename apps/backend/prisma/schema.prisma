// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
  engineType = "client"
  runtime = "bun"
}

datasource db {
  provider = "sqlite"
}

model users {
  id             Int              @id @default(autoincrement())
  email          String           @unique
  name           String?
  profile_url    String?
  score_max      Int              @default(0)
  score          Int              @default(0)
  user_questions user_questions[]
}

model questions {
  id             Int              @id @default(autoincrement())
  category       Int // 1. BunJS, 2. TailwindCSS, 3. Git & Github, 4. ElysiaJS 
  language       Int // 1. js/ts, 2. css, 3. Bash, 4. HTML 
  type           Int // 1. quiz single answer, 2. quiz multi answer, 3. code fill (exact), 4. code fill (regex) 
  question       String
  answer         String
  correct_answer String
  difficulty     Int
  points         Int
  user_questions user_questions[]
}

model user_questions { // pertanyaan yang berhasil di jawab
  user_id     Int
  question_id Int
  user        users     @relation(fields: [user_id], references: [id])
  question    questions @relation(fields: [question_id], references: [id])

  @@id([user_id, question_id]) // composite primary key
}