{
  "name": "backend",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "devt": "bun run dev:turso",
    "db:sql": "bun prisma/query.ts",
    "db:seed": "bun prisma/seed.ts",
    "start": "bun dist/index.mjs",
    "build": "prisma generate && tsdown",
    "postinstall": "prisma generate",
    "dev:turso": "bun --env-file=.env.production src/index.ts",
    "prod:sql": "bunx prisma migrate diff --from-empty --to-schema prisma/schema.prisma --script > baseline.sql",
    "prod:check-env": "bun --env-file=.env.production -e \"console.log(process.env.DATABASE_URL)\"",
    "prod:migrate": "bun --env-file=.env.production prisma/query.ts",
    "prod:seed": "bun --env-file=.env.production prisma/seed.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/swagger": "^1.3.1",
    "@prisma/adapter-libsql": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "elysia": "^1.4.28",
    "shared": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "prisma": "^7.5.0",
    "tsdown": "^0.21.4"
  }
}