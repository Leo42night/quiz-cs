{
  "name": "monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "start": "bun run --filter '*' start",
    "dev:frontend": "bun run --filter frontend dev",
    "dev:backend": "bun run --filter backend dev",
    "start:be": "cd apps/backend && bun run start",
    "build:be": "bun run --filter backend build",
    "build": "bun run --filter '*' build"
  }
}