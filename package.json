{
  "name": "monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "devh": "bun run --filter '*' devh",
    "devt": "bun run --env-file=apps/backend/.env.production --filter '*' devt",
    "db:dump": "bun run --filter backend db:dump",
    "db:seed": "bun run --filter backend db:seed",
    "prod:sql": "bun run --env-file=apps/backend/.env.production --filter backend prod:sql",
    "prod:seed": "bun run --env-file=apps/backend/.env.production --filter backend db:seed",
    "start": "bun run --filter '*' start",
    "dev:frontend": "bun run --filter frontend dev",
    "dev:backend": "bun run --filter backend dev",
    "start:be": "cd apps/backend && bun run start",
    "build:be": "bun run --filter backend build",
    "build": "bun run --filter '*' build"
  }
}